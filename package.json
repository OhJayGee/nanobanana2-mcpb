{
  "name": "nanobanana-mcpb",
  "version": "1.3.2",
  "description": "Nanobanana Image Studio — MCP Bundle for Claude Desktop",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "NODE_NO_WARNINGS=1 NANOBANANA_TEST=1 node --test test/*.test.js",
    "scan": "semgrep --config=auto server/index.js",
    "build": "esbuild server/index.js --bundle --platform=node --format=esm --outfile=dist/index.js --external:node:* --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "pack": "npm run build && npx @anthropic-ai/mcpb pack",
    "validate": "npx @anthropic-ai/mcpb validate manifest.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
